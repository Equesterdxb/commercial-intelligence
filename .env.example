# Booking system (Equester's own simulator booking API)
BOOKING_API_BASE_URL=https://api.equester.ae
BOOKING_ADMIN_EMAIL=reporting@equester.ae
BOOKING_ADMIN_PASSWORD=your_password_here

# Meta Ads (system user token from Equester app)
META_ACCESS_TOKEN=your_meta_access_token_here
META_AD_ACCOUNT_ID=your_meta_ad_account_id_here

# Social Content (Facebook Pages + Instagram Business)
FACEBOOK_PAGE_ID=your_facebook_page_id_here
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_instagram_business_account_id_here

# Google Ads (manager account + linked ad account)
GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token_here
GOOGLE_ADS_CLIENT_ID=your_client_id_here
GOOGLE_ADS_CLIENT_SECRET=your_client_secret_here
GOOGLE_ADS_REFRESH_TOKEN=your_refresh_token_here
GOOGLE_ADS_CUSTOMER_ID=your_customer_id_here
GOOGLE_ADS_LOGIN_CUSTOMER_ID=your_login_customer_id_here

# Google Analytics 4 (GA4) – service account auth
GA4_PROPERTY_ID=your_ga4_property_id_here
GA4_SERVICE_ACCOUNT_JSON_PATH=credentials/ga4-service-account.json

# TikTok for Developers (Display API – organic content only)
TIKTOK_CLIENT_KEY=your_tiktok_client_key_here
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret_here
TIKTOK_REFRESH_TOKEN=your_tiktok_refresh_token_here
